generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  patente           String                   @id
  nombre            String
  apellido          String
  celular           String
  tipo_vehiculo     TipoVehiculo
  clienteMensual    Boolean                  @default(false)
  tipoMensual       String?
  createdAt         DateTime                 @default(now())
  turnos            Turno[]
  movimientos       MovimientoCaja[]
  estadiasMensuales EstacionamientoMensual[]
}

model Turno {
  id                 Int          @id @default(autoincrement())
  patente            String?
  cliente            Cliente?     @relation(fields: [patente], references: [patente])
  tipo_vehiculo      TipoVehiculo
  servicio           String?      @default("completo")
  fecha              DateTime     @db.Date
  hora_inicio        DateTime     @db.Time
  hora_fin           DateTime     @db.Time
  estado             EstadoTurno  @default(pendiente)
  creadoPor          CreadoPor    @default(web)
  tokenModificacion  String       @unique @default(uuid())
  createdAt          DateTime     @default(now())
  movimiento         MovimientoCaja?
}

model MovimientoCaja {
  id          Int            @id @default(autoincrement())
  fecha       DateTime       @default(now())
  tipo        TipoMovimiento
  patente     String?
  cliente     Cliente?       @relation(fields: [patente], references: [patente])
  conceptoId  Int?
  concepto    Concepto?      @relation(fields: [conceptoId], references: [id])
  monto       Decimal        @db.Decimal(10, 2)
  descripcion String?
  horaEntrada DateTime?
  horaSalida  DateTime?
  turnoId     Int?           @unique
  turno       Turno?         @relation(fields: [turnoId], references: [id])
}

model Concepto {
  id           Int            @id @default(autoincrement())
  nombre       String
  tipoConcepto TipoConcepto
  activo       Boolean        @default(true)
  movimientos  MovimientoCaja[]
}

model ConfiguracionLavado {
  tipo_vehiculo     TipoVehiculo @id
  precio            Decimal      @db.Decimal(10, 2)
  duracion_minutos  Int
  activo            Boolean      @default(true)
}

model ConfiguracionServicio {
  id               Int    @id @default(autoincrement())
  tipo_vehiculo    String
  servicio         String
  precio           Decimal @db.Decimal(10, 2)
  duracion_minutos Int
  activo           Boolean @default(true)

  @@unique([tipo_vehiculo, servicio])
}

model ConfiguracionGeneral {
  clave String @id
  valor String
}

model EstacionamientoMensual {
  id          Int       @id @default(autoincrement())
  patente     String
  cliente     Cliente?  @relation(fields: [patente], references: [patente])
  tipo        String    // mensual_completa | mensual_media
  mes         Int
  anio        Int
  fechaAlta   DateTime  @default(now())
  estado      String    @default("pendiente") // pendiente | pagado
  montoPagado Decimal?  @db.Decimal(10, 2)
  fechaPago   DateTime?

  @@unique([patente, mes, anio])
}

enum TipoVehiculo {
  auto
  camioneta
  suv
  moto
}

enum EstadoTurno {
  pendiente
  confirmado
  completado
  cancelado
}

enum CreadoPor {
  web
  empleado
  admin
}

enum TipoMovimiento {
  lavado
  estacionamiento
  ingreso
  egreso
  gasto
}

enum TipoConcepto {
  ingreso
  egreso
  gasto
}
